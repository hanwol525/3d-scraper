# Copy to .env and fill in what you have. Missing values just mark that
# provider "unconfigured" in the picker — nothing crashes.
# NASA 3D and Smithsonian 3D need no keys at all.

# --- Ready providers ---
THINGIVERSE_TOKEN=            # App token from thingiverse.com/apps/create
SMITHSONIAN_API_KEY=          # Free key from api.data.gov/signup (Open Access API)
GITHUB_TOKEN=                 # Optional; raises GitHub API rate limit for NASA 3D

# --- Gated providers (self-serve keys) ---
MYMINIFACTORY_API_KEY=        # From your MyMiniFactory account settings (search/metadata only)
CULTS3D_USERNAME=             # Your Cults3D account username
CULTS3D_API_KEY=              # Generate at cults3d.com/en/api/keys

# NOTE: Yeggi, GrabCAD, YouMagine, Thangs, and NIH 3D have no usable public
# APIs as of 2026-07-03 (verified against live docs), so no keys exist for
# them. See README §Provider status for what was found.

# --- App config ---
DOWNLOAD_DIR=./downloads
REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_DELAY_SECONDS=1    # polite delay between requests per provider
